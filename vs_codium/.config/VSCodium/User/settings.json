{
    "window.zoomLevel": 1,
    "editor.fontSize": 16,
    "editor.fontFamily": "'JetBrainsMono Nerd Font Mono', monospace",
    "editor.fontLigatures": true,
    "editor.cursorSurroundingLines": 6,
    "workbench.settings.applyToAllProfiles": [
        "editor.fontSize"
    ],
    "workbench.iconTheme": "material-icon-theme",
    "git.confirmSync": false,
    "workbench.sideBar.experimental.fontSize": 16,
    "workbench.bottomPane.experimental.fontSize": 16,
    "workbench.experimental.fontSize": 16,
    "workbench.sideBar.experimental.fontFamily": "IBM Plex Sans",
    "workbench.experimental.fontFamily": "IBM Plex Sans",
    "workbench.statusBar.experimental.fontFamily": "IBM Plex Sans",
    "workbench.tabs.experimental.fontFamily": "IBM Plex Sans",
    "workbench.tabs.experimental.fontSize": 16,
    "workbench.statusBar.experimental.fontSize": 16,
    "workbench.activityBar.experimental.fontFamily": "IBM Plex Sans",
    "scm.inputFontSize": 16,
    "editor.codeLensFontSize": 16,
    "editor.inlayHints.fontSize": 16,
    "editor.minimap.sectionHeaderFontSize": 16,
    "editor.suggestFontSize": 16,
    "chat.editor.fontSize": 16,
    "chat.fontSize": 16,
    "debug.console.fontSize": 16,
    "terminal.integrated.fontSize": 16,
    "notebook.markup.fontSize": 16,
    "notebook.output.fontSize": 16,
    "markdown.preview.fontSize": 16,
    "git.enableSmartCommit": true,
    "python.languageServer": "Pylance"
}